import os
import re
import sqlite3
import hashlib
import json
from datetime import datetime, timezone
from threading import Lock

from config import SQLITE_DB_PATH, AUDIT_LOG_PATH

# --- Global singleton connection -------------------------------------------

_conn: sqlite3.Connection | None = None
_conn_lock = Lock()


def get_conn() -> sqlite3.Connection:
    global _conn
    if _conn is None:
        with _conn_lock:
            if _conn is None:
                _conn = _open_db()
    return _conn


def _open_db() -> sqlite3.Connection:
    os.makedirs(os.path.dirname(SQLITE_DB_PATH) or ".", exist_ok=True)
    conn = sqlite3.connect(SQLITE_DB_PATH, check_same_thread=False)
    conn.row_factory = sqlite3.Row

    # Performance pragmas (mandatory for concurrent / large-scale use)
    cur = conn.cursor()
    cur.execute("PRAGMA journal_mode=WAL;")
    cur.execute("PRAGMA synchronous=NORMAL;")
    cur.execute("PRAGMA temp_store=MEMORY;")
    cur.execute("PRAGMA mmap_size=2000000000;")   # 2 GB mmap
    cur.execute("PRAGMA cache_size=-64000;")       # 64 MB page cache
    cur.execute("PRAGMA foreign_keys=ON;")

    _create_schema(conn)
    return conn


def _create_schema(conn: sqlite3.Connection) -> None:
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS doc_metadata (
            rowid           INTEGER PRIMARY KEY,
            filename        TEXT    UNIQUE NOT NULL,
            category        TEXT    DEFAULT '',
            case_number     TEXT    DEFAULT '',
            agency_name     TEXT    DEFAULT '',
            agency_name_norm TEXT   DEFAULT '',   -- lowercase, stripped (prefix-index)
            ref_number      TEXT    DEFAULT '',
            tender_amount   TEXT    DEFAULT '',
            schedule_discount TEXT  DEFAULT '',
            date_casting    TEXT    DEFAULT '',
            date_testing    TEXT    DEFAULT '',
            wo_number       TEXT    DEFAULT '',
            division        TEXT    DEFAULT '',
            plot_number     TEXT    DEFAULT '',
            plot_size       TEXT    DEFAULT '',
            deposit_amount  TEXT    DEFAULT '',
            scheme_name     TEXT    DEFAULT '',
            allottee_name   TEXT    DEFAULT '',
            allottee_norm   TEXT    DEFAULT '',   -- lowercase, stripped
            maturity_date   TEXT    DEFAULT '',
            fd_account      TEXT    DEFAULT '',
            ocr_quality     REAL    DEFAULT 1.0,  -- 0.0-1.0; flag if < 0.5
            indexed_at      TEXT    DEFAULT ''
        );

        -- Standard B-tree indexes (prefix search usable)
        CREATE INDEX IF NOT EXISTS idx_agency_norm
            ON doc_metadata(agency_name_norm);
        CREATE INDEX IF NOT EXISTS idx_plot
            ON doc_metadata(plot_number);
        CREATE INDEX IF NOT EXISTS idx_case
            ON doc_metadata(case_number);
        CREATE INDEX IF NOT EXISTS idx_ref
            ON doc_metadata(ref_number);
        CREATE INDEX IF NOT EXISTS idx_allottee_norm
            ON doc_metadata(allottee_norm);

        -- FTS5 virtual table for flexible name search at scale
        CREATE VIRTUAL TABLE IF NOT EXISTS doc_fts USING fts5(
            filename,
            agency_name,
            allottee_name,
            scheme_name,
            division,
            content='doc_metadata',
            content_rowid='rowid'
        );

        -- Keep FTS in sync automatically
        CREATE TRIGGER IF NOT EXISTS trg_fts_insert
        AFTER INSERT ON doc_metadata BEGIN
            INSERT INTO doc_fts(rowid, filename, agency_name, allottee_name, scheme_name, division)
            VALUES (new.rowid, new.filename, new.agency_name, new.allottee_name, new.scheme_name, new.division);
        END;

        CREATE TRIGGER IF NOT EXISTS trg_fts_update
        AFTER UPDATE ON doc_metadata BEGIN
            INSERT INTO doc_fts(doc_fts, rowid, filename, agency_name, allottee_name, scheme_name, division)
            VALUES ('delete', old.rowid, old.filename, old.agency_name, old.allottee_name, old.scheme_name, old.division);
            INSERT INTO doc_fts(rowid, filename, agency_name, allottee_name, scheme_name, division)
            VALUES (new.rowid, new.filename, new.agency_name, new.allottee_name, new.scheme_name, new.division);
        END;

        CREATE TRIGGER IF NOT EXISTS trg_fts_delete
        AFTER DELETE ON doc_metadata BEGIN
            INSERT INTO doc_fts(doc_fts, rowid, filename, agency_name, allottee_name, scheme_name, division)
            VALUES ('delete', old.rowid, old.filename, old.agency_name, old.allottee_name, old.scheme_name, old.division);
        END;

        CREATE TABLE IF NOT EXISTS tender_bidders (
            id            INTEGER PRIMARY KEY AUTOINCREMENT,
            filename      TEXT    NOT NULL,
            bidder_name   TEXT    NOT NULL,
            bid_amount    TEXT    DEFAULT '',
            rank          TEXT    DEFAULT '',
            UNIQUE(filename, bidder_name)
        );

        CREATE TABLE IF NOT EXISTS tender_metadata (
            tender_id       INTEGER PRIMARY KEY AUTOINCREMENT,
            filename        TEXT    UNIQUE NOT NULL,
            tender_title    TEXT    DEFAULT '',
            department      TEXT    DEFAULT '',
            location        TEXT    DEFAULT '',
            nit_number      TEXT    DEFAULT '',
            estimated_value TEXT    DEFAULT '',
            date            TEXT    DEFAULT ''
        );

        CREATE TABLE IF NOT EXISTS tender_documents (
            doc_id          INTEGER PRIMARY KEY AUTOINCREMENT,
            tender_id       INTEGER,
            filename        TEXT,
            page            INTEGER,
            chunk_id        TEXT,
            FOREIGN KEY(tender_id) REFERENCES tender_metadata(tender_id)
        );
    """)
    conn.commit()


# --- Ingestion helpers -------------------------------------------------------

def _norm(val: str) -> str:
    """Normalize a name for prefix-index lookups."""
    return re.sub(r'\s+', ' ', val.lower().strip())


def upsert_doc_metadata(filename: str, fields: dict, ocr_quality: float = 1.0) -> None:
    """Insert or replace one row. Called during indexing per PDF."""
    conn = get_conn()
    now  = datetime.now(timezone.utc).isoformat()
    conn.execute("""
        INSERT INTO doc_metadata
            (filename, category, case_number,
             agency_name, agency_name_norm,
             ref_number, tender_amount, schedule_discount,
             date_casting, date_testing, wo_number, division,
             plot_number, plot_size, deposit_amount,
             scheme_name, allottee_name, allottee_norm,
             maturity_date, fd_account, ocr_quality, indexed_at)
        VALUES
            (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        ON CONFLICT(filename) DO UPDATE SET
            category=excluded.category,
            case_number=excluded.case_number,
            agency_name=excluded.agency_name,
            agency_name_norm=excluded.agency_name_norm,
            ref_number=excluded.ref_number,
            tender_amount=excluded.tender_amount,
            schedule_discount=excluded.schedule_discount,
            date_casting=excluded.date_casting,
            date_testing=excluded.date_testing,
            wo_number=excluded.wo_number,
            division=excluded.division,
            plot_number=excluded.plot_number,
            plot_size=excluded.plot_size,
            deposit_amount=excluded.deposit_amount,
            scheme_name=excluded.scheme_name,
            allottee_name=excluded.allottee_name,
            allottee_norm=excluded.allottee_norm,
            maturity_date=excluded.maturity_date,
            fd_account=excluded.fd_account,
            ocr_quality=excluded.ocr_quality,
            indexed_at=excluded.indexed_at
    """, (
        filename,
        fields.get("category", ""),
        fields.get("case_number", ""),
        fields.get("Agency Name", ""),
        _norm(fields.get("Agency Name", "")),
        fields.get("Ref. Number", ""),
        fields.get("Tender Amount", ""),
        fields.get("Schedule Discount", ""),
        fields.get("Date of Casting", ""),
        fields.get("Date of Testing", ""),
        fields.get("W.O. Number", ""),
        fields.get("Name of Division", ""),
        fields.get("Plot Number", ""),
        fields.get("Plot Size", ""),
        fields.get("Deposit Amount", ""),
        fields.get("Scheme Name", ""),
        fields.get("Allottee Name", ""),
        _norm(fields.get("Allottee Name", "")),
        fields.get("Maturity Date", ""),
        fields.get("FD Account No", ""),
        ocr_quality,
        now,
    ))
    conn.commit()


def upsert_tender_bidders(filename: str, bidders: list[dict]) -> None:
    """Insert or replace arrays of bidder mappings into the tender_bidders table."""
    conn = get_conn()
    conn.execute("DELETE FROM tender_bidders WHERE filename = ?", (filename,))
    if bidders:
        conn.executemany("""
            INSERT INTO tender_bidders (filename, bidder_name, bid_amount, rank)
            VALUES (?, ?, ?, ?)
        """, [(filename, b.get("name", ""), b.get("amount", ""), b.get("rank", "")) for b in bidders])
    conn.commit()


def batch_upsert(records: list[tuple]) -> None:
    """Batch insert — commit every 500 rows for ingestion speed."""
    conn = get_conn()
    sql = """
        INSERT INTO doc_metadata
            (filename, category, case_number,
             agency_name, agency_name_norm,
             ref_number, tender_amount, schedule_discount,
             date_casting, date_testing, wo_number, division,
             plot_number, plot_size, deposit_amount,
             scheme_name, allottee_name, allottee_norm,
             maturity_date, fd_account, ocr_quality, indexed_at)
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        ON CONFLICT(filename) DO UPDATE SET
            agency_name=excluded.agency_name,
            agency_name_norm=excluded.agency_name_norm,
            ref_number=excluded.ref_number,
            tender_amount=excluded.tender_amount,
            schedule_discount=excluded.schedule_discount,
            date_casting=excluded.date_casting,
            date_testing=excluded.date_testing,
            wo_number=excluded.wo_number,
            division=excluded.division,
            plot_number=excluded.plot_number,
            plot_size=excluded.plot_size,
            deposit_amount=excluded.deposit_amount,
            scheme_name=excluded.scheme_name,
            allottee_name=excluded.allottee_name,
            allottee_norm=excluded.allottee_norm,
            maturity_date=excluded.maturity_date,
            fd_account=excluded.fd_account,
            ocr_quality=excluded.ocr_quality,
            indexed_at=excluded.indexed_at
    """
    BATCH = 500
    for i in range(0, len(records), BATCH):
        conn.executemany(sql, records[i:i + BATCH])
        conn.commit()
        print(f"  [metadata_db] batch upsert {min(i + BATCH, len(records))}/{len(records)}")


def clear_metadata() -> None:
    conn = get_conn()
    conn.execute("DELETE FROM doc_metadata")
    conn.execute("DELETE FROM doc_fts")
    conn.execute("DELETE FROM tender_bidders")
    conn.commit()


# --- Query helpers -----------------------------------------------------------

def _rows_to_dicts(rows) -> list[dict]:
    return [dict(r) for r in rows]


def query_by_agency(name_fragment: str, limit: int = 5) -> list[dict]:
    """
    Try FTS5 first (flexible, handles partial names).
    Fall back to prefix LIKE on normalized column.
    """
    conn  = get_conn()
    frag  = name_fragment.strip()

    # FTS5 — handles 'BALAJI EARTH' even if user typed 'BALAJI ARTH'
    try:
        rows = conn.execute(
            "SELECT m.* FROM doc_fts f JOIN doc_metadata m ON f.rowid = m.rowid "
            "WHERE doc_fts MATCH ? ORDER BY rank LIMIT ?",
            (frag, limit)
        ).fetchall()
        if rows:
            return _rows_to_dicts(rows)
    except Exception:
        pass

    # Prefix fallback on normalized column
    norm_frag = _norm(frag)
    rows = conn.execute(
        "SELECT * FROM doc_metadata WHERE agency_name_norm LIKE ? LIMIT ?",
        (norm_frag + "%", limit)
    ).fetchall()
    return _rows_to_dicts(rows)


def query_by_plot(plot_no: str, limit: int = 5) -> list[dict]:
    conn = get_conn()
    rows = conn.execute(
        "SELECT * FROM doc_metadata WHERE plot_number = ? LIMIT ?",
        (plot_no.strip(), limit)
    ).fetchall()
    if not rows:
        # fuzzy — strip separators
        clean = re.sub(r'[\s\-/]', '', plot_no)
        rows  = conn.execute(
            "SELECT * FROM doc_metadata WHERE REPLACE(REPLACE(REPLACE(plot_number,'-',''),'/',''),' ','') = ? LIMIT ?",
            (clean, limit)
        ).fetchall()
    return _rows_to_dicts(rows)


def query_by_allottee(name_fragment: str, limit: int = 5) -> list[dict]:
    conn = get_conn()
    try:
        rows = conn.execute(
            "SELECT m.* FROM doc_fts f JOIN doc_metadata m ON f.rowid = m.rowid "
            "WHERE doc_fts MATCH ? ORDER BY rank LIMIT ?",
            (name_fragment.strip(), limit)
        ).fetchall()
        if rows:
            return _rows_to_dicts(rows)
    except Exception:
        pass
    norm_frag = _norm(name_fragment)
    rows = conn.execute(
        "SELECT * FROM doc_metadata WHERE allottee_norm LIKE ? LIMIT ?",
        (norm_frag + "%", limit)
    ).fetchall()
    return _rows_to_dicts(rows)


def query_bidders_for_tender(filename: str) -> list[dict]:
    conn = get_conn()
    rows = conn.execute(
        "SELECT bidder_name, bid_amount, rank FROM tender_bidders WHERE filename = ?",
        (filename,)
    ).fetchall()
    return _rows_to_dicts(rows)


def get_all_fields_for_file(filename: str) -> dict | None:
    conn = get_conn()
    row  = conn.execute(
        "SELECT * FROM doc_metadata WHERE filename = ?", (filename,)
    ).fetchone()
    return dict(row) if row else None


# --- Audit logging -----------------------------------------------------------

_audit_lock = Lock()


def write_audit(query: str, intents: list, doc_ids: list,
                chunks_returned: int, llm_used: bool) -> None:
    """
    Append one JSON line to audit.jsonl.
    Raw query is NEVER written — only its SHA-256 hash.
    """
    entry = {
        "ts":              datetime.now(timezone.utc).isoformat(),
        "q_hash":          hashlib.sha256(query.encode()).hexdigest()[:16],
        "intents":         intents,
        "doc_ids":         [d.split("/")[-1] for d in doc_ids],
        "chunks_returned": chunks_returned,
        "llm_used":        llm_used,
    }
    line = json.dumps(entry, ensure_ascii=False)
    with _audit_lock:
        try:
            with open(AUDIT_LOG_PATH, "a", encoding="utf-8") as f:
                f.write(line + "\n")
        except Exception as e:
            print(f"  [audit] write failed: {e}")
